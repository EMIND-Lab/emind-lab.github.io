@article{kim2025vehicle,
  title={Influence of vehicle expertise on acceleration profile preferences in electric vehicles},
  author={Kim, S. and Yang, J. and Jeong, E.},
  journal={PLOS ONE},
  volume={20},
  number={6},
  pages={e0325331},
  year={2025},
  abbr={PLOS ONE},
  abstract={This study examines how professional expertise influences acceleration profile preferences by comparing evaluations from development experts in internal combustion engine vehicles (ICEVs) and electric vehicles (EVs). Subjective evaluations were conducted under light and middle tip-in acceleration conditions, where participants assessed five distinct acceleration profiles defined by maximum jerk, acceleration gradient, and jerk kurtosis. Results indicated that ICEV experts preferred profiles emphasizing stability and smooth transitions, while EV experts showed more balanced preferences for responsiveness and smoothness.}
}

@article{kang2025soundscape,
