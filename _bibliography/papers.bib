  author={Kang, Y-S. and Jeong, E.},
  journal={The Journal of the Acoustical Society of Korea},
  volume={44},
  number={3},
  pages={281--293},
  year={2025},
  abbr={JASK},
  abstract={The purpose of the study was to develop a music based soundscape and to evaluate its effects on perceived restorativeness, perceived stress and mood states. The results revealed that the experimental group showed significant improvements in all dimensions of perceived restorativeness and a significant reduction in negative stress factors compared to the control group.}
}

@article{cheon2024noise,
